{
  "name": "checkmate-ai-profile",
  "version": "1.0.0",
  "description": "AI-powered developer profile creator",
  "engines": {
    "node": ">=21.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "cypress run",
    "test:e2e:dev": "cypress open",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "format": "prettier --write .",
    "generate-pwa-assets": "pwa-assets-generator",
    "serve:https": "serve dist --ssl-cert ./cert/cert.pem --ssl-key ./cert/key.pem",
    "generate-cert": "node ./scripts/generate-ssl-cert.js",
    "deploy": "node ./scripts/deploy.js",
    "security:audit": "npm audit && npm audit fix",
    "csp-report-server": "node ./scripts/csp-report-server.js",
    "serve:secure": "node ./scripts/server.js",
    "serve:production": "cross-env NODE_ENV=production node ./scripts/server.js"
  },
  "dependencies": {
    "vue": "^3.2.31",
    "qrcode-generator": "^1.4.4",
    "@auth0/auth0-spa-js": "^1.13.0",
    "gsap": "^3.9.1",
    "jspdf": "^3.0.1",
    "html2canvas": "^1.4.1",
    "html-to-pdfmake": "^2.4.25",
    "pdfmake": "^0.2.7",
    "marked": "^9.1.0",
    "helmet": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/jspdf": "^2.0.0",
    "@types/html2canvas": "^1.0.0",
    "@types/pdfmake": "^0.2.2",
    "@types/marked": "^5.0.1",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/test-utils": "^2.3.0",
    "@vitest/coverage-v8": "^0.34.6",
    "cypress": "^13.6.0",
    "jsdom": "^22.1.0",
    "typescript": "^4.9.0",
    "vite": "^4.0.0",
    "vite-plugin-pwa": "^0.16.4",
    "pwa-asset-generator": "^6.3.1",
    "workbox-window": "^7.0.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^1.0.0",
    "eslint": "^8.26.0",
    "eslint-plugin-vue": "^9.7.0",
    "prettier": "^2.7.1",
    "devcert": "^1.2.2",
    "serve": "^14.2.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet-csp": "^3.4.0",
    "cross-env": "^7.0.3"
  }
}
